{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "snapshot": true,
  "autoupdate": true,
  "share": "manual",
  "permission": {
    "read": {
      "*": "allow"
    },
    "glob": {
      "*": "allow"
    },
    "bash": {
      "*": "ask",
      "mkdir*": "allow",
      "ls*": "allow",
      "cat*": "allow",
      "grep*": "allow",
      "find*": "allow",
      "sort*": "allow",
      "head*": "allow",
      "tail*": "allow",
      "bash -n*": "allow",
      "shellcheck*": "allow"
    }
  },
  "agent": {
    "java-modernizer": {
      "description": "Modernizes Java projects",
      "mode": "subagent"
    }
  }
}
